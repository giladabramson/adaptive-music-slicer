# Python
__pycache__/
*.py[cod]
.venv/
.venv-cuda/
*.egg-info/

# ML model weights — downloaded on demand, too large for git
.models/

# Secrets — never commit API keys (repo is public)
.env
.env.*
*.pem
*.key

# Engine I/O — generated artifacts, not source
output/
output*/
_work/
*.wav
*.mp3
*.flac
config.json
# keep a sample input if you add one (comment on its own line —
# git does not support inline comments in .gitignore patterns)
!input_track.mp3
# Landing-page audio assets — these ARE source files for the public
# site, not generated artifacts. Re-include them past the broad
# *.mp3 / *.wav rules above.
!landing/audio/**

# OS / editor
.DS_Store
Thumbs.db
